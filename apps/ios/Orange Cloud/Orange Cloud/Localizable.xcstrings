            "value" : "Zum Löschen wischen; zum Ändern von Aktion und Notizen tippen. Das Übereinstimmungsziel kann nicht geändert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe to delete; tap to change action and notes. The match target can’t be changed."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza para eliminar; toca para cambiar la acción y las notas. El objetivo no se puede cambiar."
