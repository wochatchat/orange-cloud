          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu kuyruktaki tüketilmemiş tüm mesajları kalıcı olarak siler. Geri alınamaz. Kuyruğun kendisi korunur."
