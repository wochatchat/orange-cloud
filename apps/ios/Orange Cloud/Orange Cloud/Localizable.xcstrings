    "暂停后队列仍会接收消息，但暂停向消费者投递。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أثناء الإيقاف المؤقت، تواصل قائمة الانتظار استقبال الرسائل لكنها تتوقف عن تسليمها للمستهلكين."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pausiert empfängt die Queue weiterhin Nachrichten, stellt sie aber nicht an Consumer zu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "While paused, the queue keeps receiving messages but stops delivering to consumers."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En pausa, la cola sigue recibiendo mensajes pero deja de entregarlos a los consumidores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En pause, la file continue de recevoir des messages mais cesse de les remettre aux consommateurs."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時停止中もキューはメッセージを受信し続けますが、コンシューマーへの配信は停止します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일시정지 중에도 대기열은 메시지를 계속 받지만 소비자에게는 전달하지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Em pausa, a fila continua recebendo mensagens, mas para de entregá-las aos consumidores."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Em pausa, a fila continua a receber mensagens, mas deixa de as entregar aos consumidores."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duraklatıldığında kuyruk mesaj almaya devam eder ancak tüketicilere teslimatı durdurur."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暫停後佇列仍會接收訊息，但暫停向消費者投遞。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暫停後佇列仍會接收訊息，但暫停向消費者投遞。"
          }
        }
      }
