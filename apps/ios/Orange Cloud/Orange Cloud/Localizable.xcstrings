    "修改 hostname 后如需对外解析，请到 DNS 自行调整代理 CNAME。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا غيّرت اسم المضيف، فعدّل بنفسك سجل CNAME عبر الوكيل في DNS ليُحلّ علنًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du den Hostnamen änderst, passe den proxied CNAME in DNS selbst an, damit er öffentlich aufgelöst wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you change the hostname, adjust the proxied CNAME in DNS yourself for it to resolve publicly."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si cambias el nombre de host, ajusta tú mismo el CNAME con proxy en DNS para que resuelva públicamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous modifiez le nom d’hôte, ajustez vous-même le CNAME proxifié dans DNS pour qu’il soit résolu publiquement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホスト名を変更した場合、外部で解決するには DNS でプロキシ CNAME を自分で調整してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "호스트 이름을 변경하면 외부에서 확인되도록 DNS에서 프록시 CNAME을 직접 조정하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você alterar o nome de host, ajuste o CNAME com proxy no DNS para que ele resolva publicamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se alterar o nome de anfitrião, ajuste o CNAME com proxy no DNS para que resolva publicamente."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ana makine adını değiştirirseniz, herkese açık çözümlenmesi için DNS’teki proxy’li CNAME’i kendiniz ayarlayın."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修改主機名稱後如需對外解析，請到 DNS 自行調整代理 CNAME。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修改主機名稱後如需對外解析，請到 DNS 自行調整代理 CNAME。"
          }
        }
      }
    },
