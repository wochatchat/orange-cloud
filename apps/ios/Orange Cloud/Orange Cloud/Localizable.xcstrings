        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime définitivement le compartiment %@ et est irréversible. Le compartiment doit être vide, sinon la suppression échoue."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この操作はバケット %@ を完全に削除し、元に戻せません。バケットは空である必要があり、そうでないと削除に失敗します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업은 버킷 %@을(를) 영구 삭제하며 되돌릴 수 없습니다. 버킷이 비어 있어야 하며 그렇지 않으면 삭제가 실패합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso exclui permanentemente o bucket %@ e não pode ser desfeito. O bucket deve estar vazio, senão a exclusão falha."
