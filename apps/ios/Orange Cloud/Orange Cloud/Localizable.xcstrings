    "Hyperdrive 为外部 Postgres / MySQL 提供连接池与查询缓存。" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يوفّر Hyperdrive تجميع الاتصالات وتخزين الاستعلامات مؤقتًا لـ Postgres/MySQL الخارجية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive bietet Connection-Pooling und Query-Caching für externe Postgres/MySQL."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive provides connection pooling and query caching for external Postgres / MySQL."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive ofrece pooling de conexiones y caché de consultas para Postgres/MySQL externos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive fournit pooling de connexions et cache de requêtes pour Postgres/MySQL externes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive は外部の Postgres／MySQL に接続プールとクエリキャッシュを提供します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive는 외부 Postgres/MySQL에 연결 풀링과 쿼리 캐시를 제공합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Hyperdrive oferece pool de conexões e cache de consultas para Postgres/MySQL externos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Hyperdrive oferece pool de ligações e cache de consultas para Postgres/MySQL externos."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive, harici Postgres/MySQL için bağlantı havuzu ve sorgu önbelleği sağlar."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive 為外部 Postgres／MySQL 提供連線池與查詢快取。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive 為外部 Postgres／MySQL 提供連線池與查詢緩存。"
          }
        }
      }
    },
    "Hyperdrive 缓存数据库的只读查询结果以降低延迟。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يخزّن Hyperdrive نتائج الاستعلامات للقراءة فقط من قاعدة البيانات مؤقتًا لتقليل زمن الاستجابة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive cacht schreibgeschützte Abfrageergebnisse der Datenbank, um die Latenz zu reduzieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive caches read-only query results from your database to reduce latency."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive almacena en caché los resultados de consultas de solo lectura de la base de datos para reducir la latencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive met en cache les résultats des requêtes en lecture seule de la base pour réduire la latence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive はデータベースの読み取り専用クエリ結果をキャッシュし、遅延を低減します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive는 데이터베이스의 읽기 전용 쿼리 결과를 캐시하여 지연 시간을 줄입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Hyperdrive armazena em cache os resultados de consultas somente leitura do banco de dados para reduzir a latência."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Hyperdrive coloca em cache os resultados de consultas só de leitura da base de dados para reduzir a latência."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive, gecikmeyi azaltmak için veritabanının salt okunur sorgu sonuçlarını önbelleğe alır."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive 快取資料庫的唯讀查詢結果以降低延遲。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hyperdrive 緩存資料庫的唯讀查詢結果以降低延遲。"
          }
        }
      }
    },
