    "决定哪些请求按查询字符串缓存" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتحكم في الطلبات التي تُخزَّن مؤقتًا حسب سلسلة الاستعلام"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steuert, welche Anfragen anhand der Query-Zeichenfolge zwischengespeichert werden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controls which requests are cached by query string"
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controla qué solicitudes se almacenan en caché según la cadena de consulta"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Détermine quelles requêtes sont mises en cache selon la chaîne de requête"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クエリ文字列に基づいてキャッシュするリクエストを制御します"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "쿼리 문자열에 따라 캐시할 요청을 제어합니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controla quais solicitações são armazenadas em cache por string de consulta"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controla que pedidos são colocados em cache por cadeia de consulta"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hangi isteklerin sorgu dizesine göre önbelleğe alınacağını denetler"
