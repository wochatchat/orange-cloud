    "密钥值出于安全无法读取，列表只显示名称。同名添加即覆盖。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يمكن قراءة قيم الأسرار لأسباب أمنية — تعرض القائمة الأسماء فقط. إضافة سر بالاسم نفسه يستبدله."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secret-Werte können aus Sicherheitsgründen nicht zurückgelesen werden – die Liste zeigt nur Namen. Ein gleichnamiges Secret überschreibt das vorhandene."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secret values can’t be read back for security — the list shows names only. Adding one with the same name overwrites it."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por seguridad, los valores de los secretos no se pueden leer; la lista solo muestra los nombres. Agregar uno con el mismo nombre lo sobrescribe."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les valeurs des secrets ne peuvent pas être relues pour des raisons de sécurité — la liste n’affiche que les noms. En ajouter un du même nom l’écrase."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シークレットの値はセキュリティ上読み取れず、リストには名前のみ表示されます。同じ名前で追加すると上書きされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "보안상 시크릿 값은 다시 읽을 수 없어 목록에는 이름만 표시됩니다. 같은 이름으로 추가하면 덮어씁니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por segurança, os valores dos segredos não podem ser lidos; a lista mostra apenas os nomes. Adicionar um com o mesmo nome o substitui."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por segurança, os valores dos segredos não podem ser lidos; a lista mostra apenas os nomes. Adicionar um com o mesmo nome substitui-o."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gizli değerler güvenlik nedeniyle geri okunamaz — liste yalnızca adları gösterir. Aynı adla eklemek üzerine yazar."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "密鑰值出於安全無法讀取，列表只顯示名稱。同名新增即覆寫。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "密鑰值出於安全無法讀取，列表只顯示名稱。同名新增即覆寫。"
          }
        }
      }
    },
    "密钥值无法读回，删除后需重新设置，不可撤销。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يمكن قراءة قيم الأسرار مجددًا؛ بعد الحذف يلزم ضبطه من جديد. لا يمكن التراجع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secret-Werte können nicht zurückgelesen werden; nach dem Löschen musst du es neu setzen. Nicht rückgängig zu machen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secret values can’t be read back; after deletion you must set it again. This can’t be undone."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los valores de los secretos no se pueden volver a leer; tras eliminarlo deberás configurarlo de nuevo. No se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les valeurs des secrets ne peuvent pas être relues ; après suppression, vous devrez le redéfinir. Irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シークレット値は読み戻せません。削除後は再設定が必要で、元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
