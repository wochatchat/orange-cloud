    "位置决定数据存放区域，选择「自动」由 Cloudflare 就近分配。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدّد الموقع مكان تخزين البيانات؛ اختر «تلقائي» ليضعها Cloudflare قريبًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Standort bestimmt, wo Daten gespeichert werden; mit „Automatisch“ platziert Cloudflare sie in der Nähe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location decides where data is stored; choose Automatic to let Cloudflare place it nearby."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ubicación decide dónde se almacenan los datos; elige Automática para que Cloudflare lo coloque cerca."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’emplacement détermine où sont stockées les données ; choisissez Automatique pour que Cloudflare les place à proximité."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ロケーションはデータの保存地域を決めます。「自動」を選ぶと Cloudflare が近くに配置します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치는 데이터 저장 지역을 결정합니다. 자동을 선택하면 Cloudflare가 가까운 곳에 배치합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A localização define onde os dados ficam; escolha Automático para o Cloudflare colocá-los por perto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A localização define onde os dados ficam; escolha Automático para o Cloudflare colocá-los por perto."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konum, verilerin nerede saklanacağını belirler; Otomatik’i seçerseniz Cloudflare yakına yerleştirir."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置決定資料存放區域，選擇「自動」由 Cloudflare 就近配置。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置決定資料存放區域，選擇「自動」由 Cloudflare 就近配置。"
          }
        }
      }
    },
