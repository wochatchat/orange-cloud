    "左滑删除，点按可改动作与备注；匹配对象不可改。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسحب للحذف؛ انقر لتغيير الإجراء والملاحظات. لا يمكن تغيير هدف المطابقة."
          }
        },
        "de" : {
          "stringUnit" : {
