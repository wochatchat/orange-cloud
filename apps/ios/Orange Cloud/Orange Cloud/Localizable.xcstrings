    "将永久删除该队列中所有未消费的消息，不可撤销。队列本身保留。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحذف نهائيًا جميع الرسائل غير المُستهلَكة في قائمة الانتظار هذه. لا يمكن التراجع. تبقى قائمة الانتظار نفسها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht alle nicht verarbeiteten Nachrichten in dieser Queue dauerhaft. Kann nicht rückgängig gemacht werden. Die Queue selbst bleibt erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanently deletes all unconsumed messages in this queue. This can’t be undone. The queue itself is kept."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina de forma permanente todos los mensajes no consumidos de esta cola. No se puede deshacer. La cola se conserva."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime définitivement tous les messages non consommés de cette file. Action irréversible. La file elle-même est conservée."
