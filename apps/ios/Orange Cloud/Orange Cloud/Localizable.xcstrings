    "权重 0–1，决定各源站分到的流量比例；关闭开关可临时摘除某源站。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوزن 0–1 يحدّد نصيب كل أصل من المرور؛ أوقِف الأصل لإزالته مؤقتًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Gewichtung 0–1 bestimmt den Traffic-Anteil jedes Origins; schalte einen Origin aus, um ihn vorübergehend zu entfernen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weight 0–1 sets each origin's share of traffic; turn an origin off to temporarily remove it."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El peso 0–1 define la proporción de tráfico de cada origen; desactiva un origen para quitarlo temporalmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le poids 0–1 définit la part de trafic de chaque origine ; désactivez une origine pour la retirer temporairement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重み 0〜1 で各オリジンのトラフィック割合を決めます。スイッチをオフにすると一時的にそのオリジンを外せます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가중치 0–1로 각 오리진의 트래픽 비율을 정합니다. 스위치를 끄면 해당 오리진을 일시적으로 제외합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O peso 0–1 define a parcela de tráfego de cada origem; desligue uma origem para removê-la temporariamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O peso 0–1 define a parcela de tráfego de cada origem; desligue uma origem para a remover temporariamente."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0–1 arası ağırlık her kökenin trafik payını belirler; bir kökeni geçici olarak kaldırmak için kapatın."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "權重 0–1，決定各來源分到的流量比例；關閉開關可暫時移除某來源。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "權重 0–1，決定各來源分到的流量比例；關閉開關可暫時移除某來源。"
          }
        }
      }
    },
