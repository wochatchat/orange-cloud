    "只会提交修改过的列。原值为 NULL 的列留空则保持 NULL。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُرسَل الأعمدة المعدَّلة فقط. الأعمدة التي كانت NULL تبقى NULL إذا تُركت فارغة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur geänderte Spalten werden übermittelt. Spalten, die NULL waren, bleiben NULL, wenn sie leer bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only changed columns are submitted. Columns that were NULL stay NULL if left empty."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo se envían las columnas modificadas. Las columnas que eran NULL se quedan en NULL si se dejan vacías."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seules les colonnes modifiées sont soumises. Les colonnes qui étaient NULL restent NULL si elles sont laissées vides."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "変更した列のみ送信されます。元が NULL の列は空のままなら NULL が維持されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "변경된 열만 제출됩니다. 원래 값이 NULL이던 열을 비워 두면 NULL로 유지됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas as colunas modificadas são enviadas. Colunas que eram NULL permanecem NULL se ficarem vazias."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas as colunas modificadas são enviadas. Colunas que eram NULL permanecem NULL se ficarem vazias."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yalnızca değiştirilen sütunlar gönderilir. NULL olan sütunlar boş bırakılırsa NULL kalır."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只會提交修改過的欄。原值為 NULL 的欄留空則保持 NULL。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只會提交修改過的欄。原值為 NULL 的欄留空則保持 NULL。"
          }
        }
      }
    },
    "只申请你需要的权限。授权后可在 Cloudflare Dashboard 随时撤销。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطلب فقط الأذونات التي تحتاجها. يمكنك إلغاؤها في أي وقت من لوحة تحكم Cloudflare."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fordere nur die Berechtigungen an, die du brauchst. Du kannst sie jederzeit im Cloudflare-Dashboard widerrufen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Request only the permissions you need. You can revoke them anytime in the Cloudflare Dashboard."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicita solo los permisos que necesites. Puedes revocarlos cuando quieras en el panel de Cloudflare."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne demandez que les permissions dont vous avez besoin. Vous pouvez les révoquer à tout moment dans le tableau de bord Cloudflare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な権限のみをリクエストしてください。認可後も Cloudflare Dashboard でいつでも取り消せます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필요한 권한만 요청하세요. 인증 후 Cloudflare 대시보드에서 언제든지 취소할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicite apenas as permissões necessárias. Você pode revogá-las quando quiser no painel da Cloudflare."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicite apenas as permissões necessárias. Pode revogá-las quando quiser no painel da Cloudflare."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yalnızca ihtiyaç duyduğunuz izinleri isteyin. Bunları Cloudflare panosundan istediğiniz zaman iptal edebilirsiniz."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只申請你需要的權限。授權後可在 Cloudflare Dashboard 隨時撤銷。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只申請你需要的權限。授權後可在 Cloudflare Dashboard 隨時撤銷。"
          }
        }
      }
    },
    "只能包含字母、数字和下划线，创建后不可重命名。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أحرف وأرقام وشرطات سفلية فقط. لا يمكن إعادة تسميته بعد الإنشاء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur Buchstaben, Zahlen und Unterstriche. Nach dem Erstellen nicht umbenennbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Letters, numbers, and underscores only. Can’t be renamed after creation."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo letras, números y guiones bajos. No se puede renombrar después de crearlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lettres, chiffres et traits de soulignement uniquement. Impossible à renommer après création."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "英数字とアンダースコアのみ。作成後は名前を変更できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "문자, 숫자, 밑줄만 사용할 수 있습니다. 생성 후에는 이름을 바꿀 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas letras, números e sublinhados. Não pode ser renomeado após a criação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas letras, números e sublinhados. Não pode ser renomeado após a criação."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yalnızca harf, rakam ve alt çizgi. Oluşturulduktan sonra yeniden adlandırılamaz."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅能包含字母、數字與底線，建立後不可重新命名。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅能包含字母、數字與底線，建立後不可重新命名。"
          }
        }
      }
