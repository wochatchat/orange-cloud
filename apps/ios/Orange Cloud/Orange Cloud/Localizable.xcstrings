          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A autorização atual não inclui a edição de regras de cache (cache-settings.write). Toque em “Reautorizar” para adicionar, sem terminar sessão."
          }
