        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir kullanıcı mesajı gönderir ve modelin yanıtını gösterir. Hesabınızın Workers AI kotasını kullanır (günde 10.000 Neuron ücretsiz)."
          }
