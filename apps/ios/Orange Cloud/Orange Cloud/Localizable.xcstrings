        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O AI Gateway adiciona cache, limite de taxa e registos às chamadas de LLM."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
