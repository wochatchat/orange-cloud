          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Önbellek süresi dolduktan sonra eski bir sonucun hâlâ sunulabileceği saniye; varsayılan 15 saniye."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
