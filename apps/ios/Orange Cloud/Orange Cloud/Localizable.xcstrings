    "管理 Cloudflare 告警需要 Notifications 权限。请到 设置 → 你的账号 重新登录以授予。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتطلب إدارة تنبيهات Cloudflare إذن Notifications. انتقل إلى الإعدادات ← حسابك وسجِّل الدخول مرة أخرى لمنحه."
          }
        },
        "de" : {
          "stringUnit" : {
