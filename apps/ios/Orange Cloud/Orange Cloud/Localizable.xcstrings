    "0 – 12 小时（43200 秒）。消息进入队列后延迟多久才投递。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 ساعة (43200 ثانية). المدة التي تتأخر فيها الرسائل بعد دخولها قائمة الانتظار قبل تسليمها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0–12 Stunden (43200 s). Wie lange Nachrichten nach dem Eintreffen in der Queue verzögert werden, bevor sie zugestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 hours (43200 s). How long messages are delayed after entering the queue before delivery."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 a 12 horas (43200 s). Cuánto se retrasan los mensajes tras entrar en la cola antes de entregarse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 heures (43200 s). Délai avant la remise des messages après leur entrée dans la file."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0〜12 時間（43200 秒）。メッセージがキューに入ってから配信されるまでの遅延時間。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0~12시간(43200초). 메시지가 대기열에 들어온 후 전달되기까지의 지연 시간입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 horas (43200 s). Quanto tempo as mensagens são adiadas após entrar na fila antes da entrega."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 horas (43200 s). Quanto tempo as mensagens são adiadas após entrarem na fila antes da entrega."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 saat (43200 sn). Mesajların kuyruğa girdikten sonra teslim edilmeden önce ne kadar geciktirileceği."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 小時（43200 秒）。訊息進入佇列後延遲多久才投遞。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 – 12 小時（43200 秒）。訊息進入佇列後延遲多久才投遞。"
          }
        }
      }
    },
