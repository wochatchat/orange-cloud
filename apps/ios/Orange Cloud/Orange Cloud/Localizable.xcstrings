        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Cloudflare ainda não retornou os servidores de nomes. Verifique mais tarde nos detalhes do domínio ou no painel da Cloudflare."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
