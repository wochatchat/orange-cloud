    "AI Gateway 为 LLM 调用提供缓存、限速与日志。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يوفّر AI Gateway التخزين المؤقت وحد المعدل والسجلات لاستدعاءات LLM."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Gateway bietet Caching, Ratenbegrenzung und Logging für LLM-Aufrufe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Gateway adds caching, rate limiting and logging to LLM calls."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Gateway añade caché, límite de tasa y registros a las llamadas de LLM."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Gateway ajoute cache, limitation de débit et journaux aux appels LLM."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Gateway は LLM 呼び出しにキャッシュ・レート制限・ログを提供します。"
