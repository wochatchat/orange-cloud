          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez les variables d’environnement et les secrets d’un Worker — ajoutez, modifiez et supprimez à la volée."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدِر متغيرات البيئة والأسرار لـ Worker — إضافة وتعديل وحذف في أي وقت."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Worker’ın ortam değişkenlerini ve gizli bilgilerini yönetin — anında ekleyin, düzenleyin ve kaldırın."
          }
        }
      }
    },
    "管理 workers.dev 子域、自定义域与路由，掌控 Worker 的访问入口。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage the workers.dev subdomain, custom domains, and routes to control how a Worker is reached."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理 workers.dev 子網域、自訂網域與路由，掌控 Worker 的存取入口。"
          }
        },
        "zh-HK": {
