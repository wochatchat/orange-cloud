          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL'ye göre önbellek temizleme"
          }
        }
      }
    },
    "按 URL 自定义边缘与浏览器缓存时长、绕过缓存，直接在手机上管理缓存规则。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customize edge and browser cache TTLs per URL or bypass cache entirely — manage cache rules right from your phone."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依 URL 自訂邊緣與瀏覽器快取時間、略過快取，直接在手機上管理快取規則。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按 URL 自訂邊緣與瀏覽器緩存時間、繞過緩存，直接在手機上管理緩存規則。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URL ごとにエッジとブラウザーのキャッシュ TTL をカスタマイズしたり、キャッシュをバイパスしたり。キャッシュルールをスマホから管理できます。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Personaliza el TTL de caché en el borde y el navegador por URL u omite la caché por completo: administra las reglas de caché desde tu teléfono."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "URL별로 엣지·브라우저 캐시 TTL을 설정하거나 캐시를 우회하세요. 캐시 규칙을 휴대폰에서 바로 관리할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize o TTL de cache na borda e no navegador por URL ou ignore o cache por completo — gerencie regras de cache direto do celular."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize o TTL de cache na extremidade e no navegador por URL ou ignore o cache por completo — faça a gestão das regras de cache diretamente do telemóvel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe Edge- und Browser-Cache-TTLs pro URL an oder umgehe den Cache ganz – verwalte Cache-Regeln direkt vom Handy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personnalisez les TTL de cache edge et navigateur par URL ou contournez complètement le cache — gérez les règles de cache depuis votre téléphone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خصّص مدة التخزين المؤقت على الحافة والمتصفح لكل عنوان URL أو تجاوز التخزين المؤقت كليًا، وأدِر قواعد التخزين المؤقت من هاتفك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "URL bazında uç ve tarayıcı önbellek TTL'lerini özelleştirin veya önbelleği tamamen atlayın — önbellek kurallarını telefonunuzdan yönetin."
          }
        }
      }
    },
    "授权更省心": {
      "localizations": {
