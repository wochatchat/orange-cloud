<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".OrangeCloudApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.OrangeCloud">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.OrangeCloud">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth 回调：Web 后端 302 跳回 orangecloud://oauth/callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="${oauthScheme}"
                    android:host="${oauthHost}" />
            </intent-filter>

            <!-- App Shortcuts / 深链直达主 Tab：orangecloud://open/{zones|workers|storage} -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="orangecloud"
                    android:host="open" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- 无痕 WebView 授权页（添加账号时用，避免 Custom Tab 复用系统浏览器 Cookie） -->
        <activity
            android:name=".core.util.WebAuthActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- R2 对象下载后用系统应用打开/分享（缓存目录临时文件） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- R2 接入系统「文件」App（SAF DocumentsProvider，只读浏览/打开 R2 对象） -->
        <provider
            android:name=".core.system.R2DocumentsProvider"
            android:authorities="${applicationId}.r2documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

        <!-- 下拉快设磁贴（QS Tile，v1 特性）：点击直达概览 -->
        <service
            android:name=".core.system.AccountTileService"
            android:exported="true"
            android:icon="@drawable/ic_launcher_foreground"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 晨昏桌面小组件（Glance）：账号总览天窗卡 -->
        <receiver
            android:name=".core.widget.OrangeCloudWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/orange_cloud_widget_info" />
        </receiver>

        <!-- 推送中心：FCM 接收服务（Firebase 未配置时系统不会调用）-->
        <service
            android:name=".core.push.OcMessagingService"
            android:exported="false">
            <intent-filter>
                <!-- 注意：action 是 com.google.firebase.MESSAGING_EVENT（无 .messaging 段）；
                     写错服务永远不被解析，前台消息静默丢、后台走 fallback 通道、onNewToken 失效 -->
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="push_center" />
    </application>
</manifest>
